<Window x:Class="DB_MVVM.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" Height="500" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgColor}">

    <Border Background="White" Margin="20" CornerRadius="12" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Поля ввода -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <TextBlock Text="Детали заказа" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryColor}"/>

            <!-- Секция ввода с фиксированными строками -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Метка Товары -->
                    <RowDefinition Height="Auto"/>
                    <!-- Поле Товары -->
                    <RowDefinition Height="Auto"/>
                    <!-- Метка Сумма -->
                    <RowDefinition Height="Auto"/>
                    <!-- Поле Сумма -->
                    <RowDefinition Height="Auto"/>
                    <!-- Метка Адрес -->
                    <RowDefinition Height="Auto"/>
                    <!-- Поле Адрес -->
                    <RowDefinition Height="Auto"/>
                    <!-- Подсказка (Самовывоз) -->
                </Grid.RowDefinitions>

                <TextBlock Text="Состав заказа (товары)" Grid.Row="0" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding Products, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="1" Height="80" TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalContentAlignment="Top" Padding="8" Margin="0,5,0,15"/>

                <TextBlock Text="Сумма (₽)" Grid.Row="2" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" 
                         Grid.Row="3" Margin="0,5,0,15" Height="35"/>

                <TextBlock Text="Адрес доставки" Grid.Row="4" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding DeliveryAddress, UpdateSourceTrigger=PropertyChanged}" 
                         Grid.Row="5" Margin="0,5,0,2" Height="35" Name="AddressBox"/>

                <!-- Та самая подсказка, теперь в отдельной строке -->
                <TextBlock Text="Оставьте пустым для самовывоза" 
                           Grid.Row="6" FontSize="11" FontStyle="Italic" 
                           Foreground="Gray" 
                           Margin="5,0,0,10"/>
            </Grid>

            <!-- Кнопки -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Оформить" Click="Accept_Click" IsDefault="True" Width="130" Background="{StaticResource SuccessColor}"/>
                <Button Content="Отмена" IsCancel="True" Width="100" Background="#95A5A6" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>