<Window x:Class="DB_MVVM.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал событий (Аудит)" Height="450" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="История всех изменений в системе" 
                   FontSize="18" FontWeight="Bold" Margin="10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Logs}" 
                  AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding Timestamp, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding Username}" Width="100"/>

                <!-- Раскрасим действия для наглядности через триггеры позже, если захочешь -->
                <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="100"/>
                <DataGridTextColumn Header="Объект" Binding="{Binding EntityName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>