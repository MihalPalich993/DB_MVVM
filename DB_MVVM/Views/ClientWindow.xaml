<Window x:Class="DB_MVVM.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка клиента" Height="620" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgColor}">

    <Border Background="White" Margin="20" CornerRadius="12" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Поля ввода -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки -->
            </Grid.RowDefinitions>

            <TextBlock Text="Данные клиента" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryColor}"/>

            <!-- Используем внутренний Grid для полей, чтобы всё было ровно -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Фамилия -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Имя -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Тел -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Email -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Адрес -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Статус -->
                </Grid.RowDefinitions>

                <TextBlock Text="Фамилия" Grid.Row="0" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Margin="0,2,0,10"/>

                <TextBlock Text="Имя" Grid.Row="2" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Margin="0,2,0,10"/>

                <TextBlock Text="Телефон" Grid.Row="4" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Margin="0,2,0,10"/>

                <TextBlock Text="E-mail" Grid.Row="6" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Grid.Row="7" Margin="0,2,0,10"/>

                <TextBlock Text="Адрес" Grid.Row="8" Foreground="Gray" Margin="5,0"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Grid.Row="9" Margin="0,2,0,10"/>

                <TextBlock Text="Статус клиента" Grid.Row="10" Foreground="Gray" Margin="5,0"/>
                <ComboBox Text="{Binding Status, UpdateSourceTrigger=PropertyChanged}" Grid.Row="11"
                          IsEditable="True" Margin="0,2,0,10" Height="35" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Обычный"/>
                    <ComboBoxItem Content="VIP"/>
                    <ComboBoxItem Content="Проблемный"/>
                </ComboBox>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сохранить" Click="Accept_Click" IsDefault="True" Width="120" Background="{StaticResource SuccessColor}"/>
                <Button Content="Отмена" IsCancel="True" Width="100" Background="#95A5A6" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>